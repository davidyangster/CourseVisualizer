<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view2="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_launcher_foreground"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:theme="@style/AppTheme.AppBarOverlay">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginLeft="30dp"
            android:text="Course Name"
            android:textColor="@android:color/white"
            android:textSize="25dp"
            ></TextView>

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/AppTheme.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <include layout="@layout/content_main" />

    <TextView
        android:id="@+id/final_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="175dp"
        android:layout_marginTop="140dp"
        android:text="Final:"
        android:textSize="25dp"
        android:textColor="@android:color/background_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/final_data_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="245dp"
        android:layout_marginTop="140dp"
        android:textSize="25dp"
        android:text="50%"
        android:textColor="@android:color/holo_blue_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/midterm_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="175dp"
        android:layout_marginTop="240dp"
        android:textSize="25dp"
        android:text="Midterm:"
        android:textColor="@android:color/background_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/midterm_data_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="290dp"
        android:layout_marginTop="240dp"
        android:textSize="25dp"
        android:text="30%"
        android:textColor="@android:color/holo_blue_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/assignment_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="175dp"
        android:layout_marginTop="340dp"
        android:textSize="25dp"
        android:text="Assignment:"
        android:textColor="@android:color/background_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/assignment_data_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="330dp"
        android:layout_marginTop="340dp"
        android:textSize="25dp"
        android:text="5%"
        android:textColor="@android:color/holo_blue_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/lab_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="175dp"
        android:layout_marginTop="440dp"
        android:text="Lab:"
        android:textSize="25dp"
        android:textColor="@android:color/background_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/lab_data_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="230dp"
        android:layout_marginTop="440dp"
        android:text="10%"
        android:textSize="25dp"
        android:textColor="@android:color/holo_blue_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/participation_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="175dp"
        android:layout_marginTop="540dp"
        android:text="Participation:"
        android:textSize="25dp"
        android:textColor="@android:color/background_dark"
        android:textStyle="bold"

        />

    <TextView
        android:id="@+id/participation_data_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="340dp"
        android:layout_marginTop="540dp"
        android:text="5%"
        android:textSize="25dp"
        android:textColor="@android:color/holo_blue_dark"
        android:textStyle="bold"

        />











    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        app:srcCompat="@android:drawable/ic_input_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>